<Page x:Class="_90s_Minimalism_CMS_Project.Pages.DataTablePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_90s_Minimalism_CMS_Project.Pages"
      Background="{StaticResource BrushBackground}"
      Title="Collection">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="40,28,40,20"
                BorderBrush="{StaticResource BrushDivider}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="THE COLLECTION"
                               FontFamily="Georgia"
                               FontSize="30"
                               Foreground="{StaticResource BrushInk}"/>
                    <TextBlock Text="90s Minimalist Fashion Archive"
                               FontSize="12"
                               Foreground="{StaticResource BrushMidtone}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="1"
                        VerticalAlignment="Center"
                        Background="{StaticResource BrushAccent}"
                        Padding="14,6"
                        CornerRadius="3">
                    <TextBlock x:Name="ItemCountText"
                               FontFamily="Gill Sans MT"
                               FontSize="11"
                               Foreground="{StaticResource BrushInk}"/>
                </Border>
            </Grid>
        </Border>
        <Border Grid.Row="1"
                Padding="40,12,40,12"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushDivider}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="SelectAllCheckBox"
                          Grid.Column="0"
                          Content="Select All"
                          VerticalAlignment="Center"
                          Checked="SelectAllCheckBox_Checked"
                          Unchecked="SelectAllCheckBox_Unchecked"
                          ToolTip="Select or deselect all items"
                          Visibility="Collapsed"/>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">
                    <Button x:Name="AddButton"
                            Content="ADD PIECE"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddButton_Click"
                            ToolTip="Add a new fashion piece"
                            Padding="14,7"
                            FontSize="11"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"/>
                    <Button x:Name="DeleteButton"
                            Content="DELETE SELECTED"
                            Style="{StaticResource DangerButton}"
                            Click="DeleteButton_Click"
                            ToolTip="Delete all checked items"
                            Padding="14,7"
                            FontSize="11"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"/>
                    <Button x:Name="ExitButton"
                            Content="EXIT"
                            Style="{StaticResource GhostButton}"
                            Click="ExitButton_Click"
                            ToolTip="Return to the login screen"
                            Padding="14,7"
                            FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
        <DataGrid x:Name="FashionItemsDataGrid"
                  Grid.Row="2"
                  Margin="40,0,40,0"
                  ItemsSource="{Binding FashionItems}"
                  SelectionChanged="FashionItemsDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTemplateColumn x:Name="CheckColumn"
                                        Header=""
                                        Width="50"
                                        Visibility="Collapsed">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      Cursor="Hand"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="NAME / DESIGNER"
                                        Width="*"
                                        SortMemberPath="Name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Padding="8,0">
                                <Hyperlink x:Name="ItemHyperlink"
                                           Click="ItemHyperlink_Click"
                                           Foreground="{StaticResource BrushInk}"
                                           TextDecorations="Underline">
                                    <Run Text="{Binding Name, Mode=OneWay}"/>
                                </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="IMAGE" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding FullImagePath}"
                                   Height="60"
                                   Width="80"
                                   Stretch="UniformToFill"
                                   Margin="4"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="DATE ADDED"
                                    Binding="{Binding DateAdded, StringFormat='{}{0:dd MMM yyyy}'}"
                                    Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushMidtone}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Border x:Name="EmptyStateBorder"
                Grid.Row="2"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="-"
                           FontFamily="Georgia"
                           FontSize="48"
                           Foreground="{StaticResource BrushDivider}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="THE COLLECTION IS EMPTY"
                           FontFamily="Gill Sans MT"
                           FontSize="13"
                           Foreground="{StaticResource BrushMidtone}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
                <TextBlock Text="Add a new fashion piece to begin."
                           FontSize="11"
                           Foreground="{StaticResource BrushMidtone}"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="3"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushDivider}"
                BorderThickness="0,1,0,0"
                Padding="40,10">
            <TextBlock x:Name="StatusText"
                       FontSize="11"
                       Foreground="{StaticResource BrushMidtone}"/>
        </Border>
    </Grid>
</Page>
