<Window x:Class="_90s_Minimalism_CMS_Project.Windows.ItemDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_90s_Minimalism_CMS_Project.Windows"
        mc:Ignorable="d"
        Title="NINETIES MINIMAL - Piece detail" 
        Height="700" Width="680"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBackground}"
        FontFamily="Gill Sans MT">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Background="{StaticResource BrushInk}"
                Padding="36,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="DetailNameText"
                               FontFamily="Georgia"
                               FontSize="26"
                               Foreground="{StaticResource BrushBackground}"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="DetailDesignerText"
                               FontSize="12"
                               Foreground="{StaticResource BrushAccent}"
                               Margin="0,6,0,0"/>
                </StackPanel>
                
                <Border Grid.Column="1"
                        Background="Transparent"
                        BorderBrush="{StaticResource BrushAccent}"
                        BorderThickness="1"
                        Padding="12,6"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="DetailCategoryText"
                               Foreground="{StaticResource BrushAccent}"
                               FontSize="10"/>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="36,28,36,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border BorderBrush="{StaticResource BrushDivider}"
                            BorderThickness="1"
                            Height="220"
                            Background="{StaticResource BrushSurface}">
                        <Image x:Name="DetailImage"
                               Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="PRICE" Style="{StaticResource FieldLabel}" />
                        <TextBlock x:Name="DetailPriceText"
                                   FontFamily="Georgia"
                                   FontSize="20"
                                   Foreground="{StaticResource BrushInk}"
                                   Margin="0,0,0,16" />
                        <Rectangle Height="1" Fill="{StaticResource BrushDivider}" Margin="0,0,0,16" />
                        <TextBlock Text="CATEGORY" Style="{StaticResource FieldLabel}" />
                        <TextBlock x:Name="DetailCategoryMetaText"
                                   FontSize="13"
                                   Foreground="{StaticResource BrushInk}"
                                   Margin="0,0,0,16" />

                        <TextBlock Text="DATE ADDED" Style="{StaticResource FieldLabel}" />
                        <TextBlock x:Name="DetailDateText"
                                   FontSize="13"
                                   Foreground="{StaticResource BrushMidtone}"
                                   Margin="0,0,0,16" />

                        <TextBlock Text="DESIGNER" Style="{StaticResource FieldLabel}" />
                        <TextBlock x:Name="DetailDesignerMetaText"
                                   FontSize="13"
                                   Foreground="{StaticResource BrushInk}"
                                   Margin="0,0,0,0" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="EDITORIAL NOTES"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,0,0,10" />
                    <Rectangle Height="2" Fill="{StaticResource BrushAccent}" Margin="0,0,0,16" />
                    <FlowDocumentScrollViewer x:Name="DescrtiptionViewer"
                                              VerticalScrollBarVisibility="Auto"
                                              Height="360"
                                              Background="{StaticResource BrushSurface}"
                                              BorderBrush="{StaticResource BrushDivider}"
                                              BorderThickness="1"
                                              Padding="12"
                                              IsSelectionEnabled="False"
                                              Zoom="100"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
        <Border Grid.Row="2"
                BorderBrush="{StaticResource BrushDivider}"
                BorderThickness="0,1,0,0"
                Padding="36, 14"
                Background="{StaticResource BrushSurface}">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="CLOSE"
                        Style="{StaticResource PrimaryButton}"
                        Width="120"
                        Click="Button_Click"
                        ToolTip="Close this detail view"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
